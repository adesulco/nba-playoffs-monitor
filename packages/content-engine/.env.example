# Gibol Content Engine — environment variables.
#
# Copy this file to `.env` (gitignored) for local dev, OR set these in
# the deployment env (Vercel / Cloudflare / GitHub Actions).
#
# Phase 0 (foundation) needs the items marked [P0]. Items marked [P1+]
# are for later phases — see STATUS.md.

# ── Anthropic API [P0] ──────────────────────────────────────────────
# Generates previews, recaps, profiles, standings explainers.
# Sonnet 4.6 default; Haiku 4.5 for templated/lint; Opus 4.7 for QC.
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# Hard daily token-budget caps per agent (in input+output tokens).
# Halt + alert if exceeded — never silently degrade or downgrade models.
# Tune after Phase 1 measurements.
ANTHROPIC_DAILY_BUDGET_PREVIEW=500000
ANTHROPIC_DAILY_BUDGET_RECAP=1000000
ANTHROPIC_DAILY_BUDGET_STANDINGS=200000
ANTHROPIC_DAILY_BUDGET_PROFILE=300000
ANTHROPIC_DAILY_BUDGET_QC=100000

# ── OpenAI embeddings [P1+] ─────────────────────────────────────────
# text-embedding-3-small for retrieval-augmented generation
# (historical context, "last 5 meetings between these teams").
# $0.02/1M input tokens. Optional but recommended for Phase 4 evergreen.
OPENAI_API_KEY=

# ── Postgres + pgvector [P0] ────────────────────────────────────────
# Same Supabase project as the web app (egzacjfbmgbcwhtvqixc) but
# accessed via direct Postgres connection for the Python engine.
# Get connection string from Supabase dashboard → Settings → Database.
DATABASE_URL=postgresql://user:password@db.egzacjfbmgbcwhtvqixc.supabase.co:5432/postgres

# Pool size for the asyncpg + psycopg connection pool. Phase 0 is
# single-process dev; Phase 1+ runs concurrent agents so bump to ≥10.
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Sports data feeds [P0] ──────────────────────────────────────────
# API-Football Pro key (already paid for the web app at $19/mo).
# Reuse the same key — separate quotas not needed at our scale.
API_FOOTBALL_KEY=

# ESPN, jolpica-f1 are unauthenticated public APIs (web app uses them
# already via /api/proxy). Content engine will hit them directly.

# ── Cloudflare Workers + Queues [P1+] ───────────────────────────────
# Real-time orchestration: final-whistle webhook → recap queue.
# Provisioned in the Phase 1 ship, not Phase 0.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_QUEUE_NAME=gibol-content-recap

# ── Observability [P1+] ─────────────────────────────────────────────
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=gibol-content-engine

# ── Publishing [P1+] ────────────────────────────────────────────────
# Public content directory in the web app repo. Engine writes JSON
# files here; web app's prerender + lazy SPA routes consume them.
# Default works when running from packages/content-engine/ within the
# same repo.
WEB_CONTENT_DIR=../../public/content

# Vercel deploy hook for kicking a rebuild after publish.
# Generated content commits are author=gibol-bot for filterability.
VERCEL_DEPLOY_HOOK=

# ── Behavior flags ──────────────────────────────────────────────────
# Phase 1 = no auto-publish. ALL articles go through manual review.
# Phase 2 flips this for non-flagship matches per CLAUDE.md rule #8.
ENABLE_AUTO_PUBLISH=false

# Voice linter strictness. score < threshold = block + regenerate.
# 4.0 default; tune after eval-set measurements.
VOICE_LINT_THRESHOLD=4.0

# External plagiarism check threshold (per response doc § 6).
# 7-gram simhash similarity > threshold to any external article = block.
PLAGIARISM_SIMHASH_THRESHOLD=0.6

# Dedup threshold against last 30d of own content. > threshold = block.
DEDUP_SIMHASH_THRESHOLD=0.85
