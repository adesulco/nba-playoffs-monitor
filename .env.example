# ─── Analytics & observability ──────────────────────────────────────────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Set this in Vercel → Project → Settings → Environment Variables → Production.
# Safe to leave empty in local dev — analytics is a no-op when unset.
VITE_GA_ID=

# Sentry DSN — crash + error reporting. From Sentry project settings.
# No-op when empty. Format: https://xxx@oXXX.ingest.sentry.io/XXX
VITE_SENTRY_DSN=

# Sentry auth token for sourcemap upload during the vite build.
# Create at https://sentry.io/settings/account/api/auth-tokens/
# Scopes: project:releases + org:read. Server-side only (never Vite-exposed).
SENTRY_AUTH_TOKEN=

# PostHog — product analytics, funnels, retention.
# Project key from https://posthog.com → Project settings → API key.
# Prefer the EU region for lower latency to Asia.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

# Vercel Speed Insights + Analytics are enabled via the dashboard toggle;
# no env var required. The @vercel/speed-insights + @vercel/analytics
# packages auto-discover the deployment ID.

# ─── Supabase (pick'em + newsletter + editorial) ────────────────────────
# Project: egzacjfbmgbcwhtvqixc (Mumbai ap-south-1, Postgres 17).
# Anon key is safe to ship to the browser — RLS enforces access.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Service role — server-only. Bypasses RLS. NEVER prefix with VITE_.
SUPABASE_SERVICE_ROLE=

# ─── Admin tokens & secrets ─────────────────────────────────────────────
# Protects /api/pickem/score + other admin endpoints.
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# Protects /api/cron/* endpoints — Vercel passes x-vercel-cron-secret header
# to cron invocations; compare against this value.
CRON_SECRET=

# ─── Push + email (Week 2 ships) ────────────────────────────────────────
# OneSignal — web push.
VITE_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Resend — transactional + newsletter. Domain `gibol.co` must be verified
# with SPF+DKIM+DMARC before first send. Sender: pagi@gibol.co.
RESEND_API_KEY=

# ─── Cache (Week 4 ship) ────────────────────────────────────────────────
# Upstash Redis — Singapore region. Free tier covers ~10k cmd/day.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Data providers (deferred — decide at end of Week 3) ────────────────
# API-Football Pro — EPL match centre, xG, Liga 1. $19/mo.
API_FOOTBALL_KEY=
# API-Tennis — draws, H2H, Indo player tracker.
API_TENNIS_KEY=
# YouTube Data API — highlight embed metadata.
YOUTUBE_API_KEY=
